---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="flex min-h-screen items-center justify-center bg-[radial-gradient(circle_at_top,_rgba(251,191,36,0.18),_transparent_45%),linear-gradient(135deg,_#020617,_#111827)] px-4 py-6">
		<div class="w-full max-w-xl rounded-[1.5rem] border border-white/10 bg-slate-900/80 p-4 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:p-6">
			<div class="mb-4 text-center">
				<h1 class="text-2xl font-black tracking-tight text-amber-400 sm:text-3xl">RTM 26 / TALLER 1</h1>
				<p class="mt-2 text-sm text-amber-100/90 sm:text-base">Ese hombre eres tú: ¿recibir identidad o construirla?</p>
			</div>

			<div class="flex items-center gap-2 rounded-full border border-white/10 bg-slate-950/80 p-2 shadow-inner shadow-black/30">
				<input
					type="text"
					placeholder="¿Qué piensas?"
					class="h-12 w-full rounded-full bg-transparent px-4 text-sm text-white outline-none placeholder:text-slate-400 focus:ring-2 focus:ring-amber-400/50 sm:text-base"
				/>
				<button class="h-11 shrink-0 rounded-full bg-amber-400 px-4 text-sm font-semibold text-slate-950 transition hover:bg-amber-300 sm:px-5">
					Enviar
				</button>
			</div>
		</div>
	</section>
</Layout>
