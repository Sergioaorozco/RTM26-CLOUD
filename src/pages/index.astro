---
import Layout from '../layouts/Layout.astro';
import InputChip from '../components/InputChip';
---

<Layout>
	<section class="flex min-h-screen items-center justify-center bg-[radial-gradient(circle_at_top,rgba(251,191,36,0.18),transparent_45%),linear-gradient(135deg,#020617,#111827)] px-4 py-6">
		<div class="w-full max-w-xl rounded-3xl border border-white/10 bg-slate-900/80 p-4 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:p-6">
			<div class="mb-4 text-center">
				<h1 class="text-2xl font-black tracking-tight text-amber-400 sm:text-3xl">RTM 26 / TALLER 1</h1>
				<p class="mt-2 text-sm text-amber-100/90 sm:text-base">Ese hombre eres tú: ¿recibir identidad o construirla?</p>
			</div>
			<InputChip client:load />
		</div>
	</section>
</Layout>
