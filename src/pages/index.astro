---
import Layout from '../layouts/Layout.astro';
import InputChip from '../components/InputChip';
---

<Layout>
	<section class="relative flex min-h-screen items-center justify-center px-4 py-6">
		<div class="pointer-events-none absolute inset-0 z-0 bg-[url(/BG_INDEX_BLUE.webp)] bg-cover bg-center" />
		<div class="pointer-events-none absolute inset-0 z-0 bg-gradient-to-b from-[#020617]/70 via-[#0f172a]/60 to-[#020617]/80" />
		<div class="relative z-10 w-full max-w-xl rounded-3xl border border-white/10 bg-slate-900/80 p-4 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:p-6">
			<div class="mb-4 text-center">
				<h1 class="text-2xl font-black tracking-tight text-amber-400 sm:text-3xl">RTM 26 - TALLER</h1>
				<p class="mt-2 text-sm text-amber-100/90 sm:text-base text-balance"> ¿Qué idea del ser humano<br class="block sm:hidden" />hace posible vivir así?</p>
			</div>
			<InputChip client:load />
		</div>
	</section>
</Layout>
